# Server
PORT=3000
LOG_LEVEL=info
TRUST_PROXY=true

# Security
BLOCK_PRIVATE_NETWORK=true
ALLOWED_ORIGINS=*

# Request and render timing
REQUEST_TIMEOUT_MS=45000
NAVIGATION_TIMEOUT_MS=30000
SCREENSHOT_TIMEOUT_MS=15000
DEFAULT_WAIT_MS=0
MAX_WAIT_MS=15000
JOB_TIMEOUT_MS=40000
SHUTDOWN_TIMEOUT_MS=20000

# Viewport bounds
DEFAULT_WIDTH=1280
DEFAULT_HEIGHT=800
MIN_WIDTH=320
MAX_WIDTH=2560
MIN_HEIGHT=240
MAX_HEIGHT=1600

# Throughput controls
MAX_CONCURRENT_JOBS=8
MAX_QUEUE_SIZE=200
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Puppeteer
PUPPETEER_HEADLESS=true
PREWARM_BROWSER=true
CHROMIUM_ARGS=--no-sandbox,--disable-setuid-sandbox,--disable-dev-shm-usage
# SCREENSHOT_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 Chrome/124.0.0.0 Safari/537.36
